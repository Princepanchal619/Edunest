# ============================================
# EduNest Frontend Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Backend API URL
REACT_APP_BASE_URL=http://localhost:4000/api/v1

# Razorpay Key ID (same as RAZORPAY_KEY in server .env)
REACT_APP_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxxxxxxxxxx
